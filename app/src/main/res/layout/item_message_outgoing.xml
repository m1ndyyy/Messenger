<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:orientation="horizontal"
    android:gravity="end">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:minWidth="200dp"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Блок пересылки -->
        <LinearLayout
            android:id="@+id/layoutForward"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_quote_reply"
            android:padding="8dp"
            android:layout_marginBottom="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvForwardedText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📩 Пересланное сообщение"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>

        <!-- Блок ответа (цитата) -->
        <LinearLayout
            android:id="@+id/layoutReply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_quote_reply"
            android:padding="8dp"
            android:layout_marginBottom="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvReplySender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/pastel_blue_dark"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReplyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:maxLines="3"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Основное сообщение -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_message_outgoing"
            android:padding="12dp"
            android:textColor="@color/message_text_outgoing"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEdited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" (ред.)"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:textSize="10sp"
                android:textColor="@color/text_hint" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/green" />

            <TextView
                android:id="@+id/tvLike"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ❤️"
                android:textSize="10sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDeleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Вы удалили сообщение"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>